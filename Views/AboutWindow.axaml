<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OneFileBox.Views.AboutWindow"
        Title="关于 OneFileBox"
        Width="360" Height="280"
        WindowStartupLocation="CenterOwner"
        
        CanResize="False"
        ShowInTaskbar="False">

    <StackPanel Margin="20" HorizontalAlignment="Center">

        <!-- App name -->
        <TextBlock Text="OneFileBox"
                   FontSize="22" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,10,0,0"/>

        <!-- Version -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <TextBlock Text="版本 " FontSize="13"/>
            <TextBlock Text="1.0.0" FontSize="13" FontWeight="Bold"/>
        </StackPanel>
        <TextBlock Text="跨平台 SVN 文件管理器" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="Gray"/>

        <!-- Description -->
        <TextBlock Text="基于 Avalonia 12 构建，使用 SVN CLI 作为版本控制后端。"
                   FontSize="12" TextWrapping="Wrap" TextAlignment="Center"
                   Margin="0,16,0,0" MaxWidth="300" Foreground="Gray"/>
        <TextBlock Text="支持 Windows / macOS / Linux"
                   FontSize="12" TextWrapping="Wrap" TextAlignment="Center"
                   Margin="0,6,0,0" Foreground="Gray"/>

        <!-- Close button -->
        <Button Content="关闭" HorizontalAlignment="Center"
                Margin="0,20,0,10" Padding="20,6"
                Click="Close_Click"/>
    </StackPanel>
</Window>