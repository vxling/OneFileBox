<Window xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:vm="using:OneFileBox_new.ViewModels"
       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="580"
       x:Class="OneFileBox_new.Views.MainWindow"
       x:DataType="vm:MainWindowViewModel"
       Title="OneFileBox"
       Height="580" Width="1100"
       MinHeight="550" MinWidth="900"
       WindowStartupLocation="CenterScreen"
       Icon="/Assets/avalonia-logo.ico"
       DragDrop.AllowDrop="True">

    <DockPanel>
        <!-- Left Sidebar: repo list + action buttons -->
        <Border DockPanel.Dock="Left" Width="200" Margin="8"
                Classes="card">
            <DockPanel>
                <!-- Sidebar header -->
                <TextBlock DockPanel.Dock="Top" Text="Repositories" FontSize="14"
                           FontWeight="SemiBold" Margin="0,0,0,8"/>

                <!-- Bottom action buttons -->
                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Margin="0,8,0,0">
                    <Separator Margin="0,4"/>
                    <Button Content="➕ Add Local"
                            Classes="accent"
                            Margin="0,0,0,8"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Command="{Binding AddLocalRepoCommand}"/>
                    <Button Content="🌐 Checkout"
                            Margin="0,0,0,8"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CheckoutCommand}"/>
                    <Separator Margin="0,4"/>
                    <Button Content="⬆️ Commit"
                            Margin="0,0,0,4"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CommitCommand}"/>
                    <Button Content="⬇️ Update"
                            Margin="0,0,0,4"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Command="{Binding UpdateCommand}"/>
                    <Separator Margin="0,4"/>
                    <Button Content="⚙️ Settings"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Command="{Binding SettingsCommand}"/>
                </StackPanel>

                <!-- Repository list -->
                <ListBox ItemsSource="{Binding Repositories}"
                         SelectedItem="{Binding SelectedRepository, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:RepositoryItemViewModel">
                            <DockPanel Margin="0,4">
                                <Button DockPanel.Dock="Right"
                                        Content="✕"
                                        Padding="4,2"
                                        Classes="outline"
                                        FontSize="11"
                                        VerticalAlignment="Center"
                                        Margin="4,0,0,0"
                                        Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).RemoveRepoCommand}"
                                        CommandParameter="{Binding}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13"/>
                                    <TextBlock Text="{Binding Path}" FontSize="10"
                                               TextTrimming="CharacterEllipsis" MaxWidth="130"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Right area: file list + status bar -->
        <Grid Margin="0,8,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- File browser area -->
            <Border Grid.Row="0" Classes="card">
                <DockPanel>
                    <!-- Path bar -->
                    <Border DockPanel.Dock="Top" Padding="12,6"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="⬆️"
                                    Padding="8,4"
                                    Margin="0,0,8,0"
                                    ToolTip.Tip="返回上级目录"
                                    Command="{Binding NavigateUpCommand}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📁" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentPath}" FontSize="13"/>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="🔄 Refresh"
                                    Padding="12,6"
                                    Command="{Binding RefreshCommand}"/>
                        </Grid>
                    </Border>

                    <!-- File list -->
                    <DataGrid ItemsSource="{Binding Files}"
                              SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="4*" MinWidth="200"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusIcon}" Width="70"/>
                            <DataGridTextColumn Header="Modified" Binding="{Binding LastModifiedDisplay}" Width="160"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding FileSizeDisplay}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="1" Classes="card" Margin="0,8,0,0" Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusText}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ItemCountText}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </Grid>
            </Border>

            <!-- Loading overlay -->
            <Border Grid.Row="0" Grid.RowSpan="2"
                    Background="#80000000"
                    IsVisible="{Binding IsLoading}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⏳ 处理中..." FontSize="16" Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
