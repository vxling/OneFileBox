<Window xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:vm="using:OneFileBox.ViewModels"
       xmlns:converters="using:OneFileBox.Converters"
       xmlns:display="using:OneFileBox.ViewModels"
       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="580"
       x:Class="OneFileBox.Views.MainWindow"
       x:DataType="vm:MainWindowViewModel"
       Title="OneFileBox"
       Height="580" Width="1100"
       MinHeight="550" MinWidth="900"
       WindowStartupLocation="CenterScreen"
       Icon="/Assets/avalonia-logo.ico"
       DragDrop.AllowDrop="True">

    <Window.Resources>
        <!-- Context menu shared across all file items -->
        <ContextMenu x:Key="FileContextMenu">
            <MenuItem Command="{Binding OpenFileCommand}">
                <MenuItem.Icon><Image Source="/Assets/Icons/MenuIconOpen.png" Width="16" Height="16"/></MenuItem.Icon>
                <MenuItem.Header>打开</MenuItem.Header>
            </MenuItem>
            <Separator/>
            <MenuItem Command="{Binding RefreshCommand}" IsEnabled="{Binding CanOperate}">
                <MenuItem.Icon><Image Source="/Assets/Icons/MenuIconRefresh.png" Width="16" Height="16"/></MenuItem.Icon>
                <MenuItem.Header>刷新</MenuItem.Header>
            </MenuItem>
            <Separator/>
            <MenuItem Command="{Binding CopyCommand}" IsEnabled="{Binding CanDelete}">
                <MenuItem.Icon><Image Source="/Assets/Icons/MenuIconCopy.png" Width="16" Height="16"/></MenuItem.Icon>
                <MenuItem.Header>复制</MenuItem.Header>
            </MenuItem>
            <Separator/>
            <MenuItem Command="{Binding PasteCommand}" IsEnabled="{Binding CanPaste}">
                <MenuItem.Icon><Image Source="/Assets/Icons/MenuIconPaste.png" Width="16" Height="16"/></MenuItem.Icon>
                <MenuItem.Header>粘贴</MenuItem.Header>
            </MenuItem>
            <Separator/>
            <MenuItem Command="{Binding DeleteFileCommand}" IsEnabled="{Binding CanDelete}">
                <MenuItem.Icon><Image Source="/Assets/Icons/MenuIconDelete.png" Width="16" Height="16"/></MenuItem.Icon>
                <MenuItem.Header>删除</MenuItem.Header>
            </MenuItem>
            <MenuItem Command="{Binding RenameFileCommand}" IsEnabled="{Binding CanRename}">
                <MenuItem.Icon><Image Source="/Assets/Icons/MenuIconRename.png" Width="16" Height="16"/></MenuItem.Icon>
                <MenuItem.Header>重命名</MenuItem.Header>
            </MenuItem>
            <Separator/>
            <MenuItem Header="📁 新建">
                <MenuItem Header="📂 文件夹" Command="{Binding NewFolderCommand}" IsEnabled="{Binding CanOperate}"/>
                <MenuItem Header="📝 文本文件.txt" Command="{Binding NewTextFileCommand}" IsEnabled="{Binding CanOperate}"/>
                <MenuItem Header="📄 Word 文档.docx" Command="{Binding NewWordDocCommand}" IsEnabled="{Binding CanOperate}"/>
                <MenuItem Header="📊 Excel 表格.xlsx" Command="{Binding NewExcelSheetCommand}" IsEnabled="{Binding CanOperate}"/>
                <MenuItem Header="📊 PowerPoint.pptx" Command="{Binding NewPowerPointCommand}" IsEnabled="{Binding CanOperate}"/>
                <MenuItem Header="🖼️ PNG 图片.png" Command="{Binding NewPngImageCommand}" IsEnabled="{Binding CanOperate}"/>
                <MenuItem Header="🖼️ BMP 图片.bmp" Command="{Binding NewBmpImageCommand}" IsEnabled="{Binding CanOperate}"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="🔀 立即同步" Command="{Binding ManualSyncCommand}" IsEnabled="{Binding CanOperate}"/>
            <MenuItem Header="📋 同步历史" Command="{Binding ToggleSyncRecordsViewCommand}"/>
            <Separator/>
            <MenuItem Header="📁 在资源管理器中显示" Command="{Binding OpenInExplorerCommand}" IsEnabled="{Binding CanDelete}"/>
        </ContextMenu>
    </Window.Resources>

    <DockPanel>
        <!-- Left Sidebar: repo list + action buttons -->
        <Border DockPanel.Dock="Left" Width="200" Margin="8"
                Classes="card">
            <DockPanel>
                <!-- Sidebar header -->
                <TextBlock DockPanel.Dock="Top" Text="Repositories" FontSize="14"
                           FontWeight="SemiBold" Margin="0,0,0,8"/>

                <!-- Bottom action buttons -->
                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Margin="0,8,0,0">
                    <Separator Margin="0,4"/>
                    <Button Content="➕ Add Local"
                            Classes="accent"
                            Margin="0,0,0,8"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Command="{Binding AddLocalRepoCommand}"/>
                    <Button Content="🌐 Checkout"
                            Margin="0,0,0,8"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CheckoutCommand}"/>
                    <Separator Margin="0,4"/>
                    <Button Content="⬆️ Commit"
                            Margin="0,0,0,4"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CommitCommand}"/>
                    <Button Content="⬇️ Update"
                            Margin="0,0,0,4"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Command="{Binding UpdateCommand}"/>
                    <Separator Margin="0,4"/>
                    <Button Content="📋 View Sync Records"
                            Margin="0,0,0,8"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ToggleSyncRecordsViewCommand}"/>
                    <Button Content="ℹ️ About"
                            Margin="0,0,0,8"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ShowAboutCommand}"/>
                    <Button Content="⚙️ Settings"
                            Padding="8,6"
                            HorizontalAlignment="Stretch"
                            Command="{Binding SettingsCommand}"/>
                </StackPanel>

                <!-- Repository list -->
                <ListBox ItemsSource="{Binding Repositories}"
                         SelectedItem="{Binding SelectedRepository, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:RepositoryItemViewModel">
                            <DockPanel Margin="0,4">
                                <Button DockPanel.Dock="Right"
                                        Content="✕"
                                        Padding="4,2"
                                        Classes="outline"
                                        FontSize="11"
                                        VerticalAlignment="Center"
                                        Margin="4,0,0,0"
                                        Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).RemoveRepoCommand}"
                                        CommandParameter="{Binding}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TypeIcon}" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Path}" FontSize="10"
                                               TextTrimming="CharacterEllipsis" MaxWidth="130"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Right area: file list + status bar -->
        <Grid Margin="0,8,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- File browser area -->
            <Border Grid.Row="0" Classes="card">
                <DockPanel>
                    <!-- Path bar -->
                    <Border DockPanel.Dock="Top" Padding="12,6"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="⬆️"
                                    Padding="8,4"
                                    Margin="0,0,8,0"
                                    ToolTip.Tip="返回上级目录"
                                    Command="{Binding NavigateUpCommand}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Path:" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{Binding CurrentPath}" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="🔄 Refresh"
                                    Padding="12,6"
                                    Command="{Binding RefreshCommand}"
                                    IsVisible="{Binding !ShowSyncRecords}"/>
                            <Button Grid.Column="2"
                                    Content="{Binding BackButtonText}"
                                    Padding="12,6"
                                    Command="{Binding CloseSyncRecordsViewCommand}"
                                    IsVisible="{Binding ShowSyncRecords}"/>
                        </Grid>
                    </Border>

                    <!-- File list with context menu + multi-select -->
                    <DataGrid x:Name="FileDataGrid" ItemsSource="{Binding Files}"
                              DoubleTapped="OnFileDoubleTapped"
                              IsVisible="{Binding !ShowSyncRecords}"
                              SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                              SelectedItems="{Binding SelectedFiles, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              ContextMenu="{DynamicResource FileContextMenu}"
                              SelectionMode="Extended"
                              CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="4*" MinWidth="200"/>
                            <DataGridTemplateColumn Header="Type" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="vm:FileItemViewModel">
                                        <Image Source="{Binding TypeIconPath}" Width="18" Height="18" Stretch="Uniform"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusIcon}" Width="70"/>
                            <DataGridTextColumn Header="Modified" Binding="{Binding LastModifiedDisplay}" Width="160"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding FileSizeDisplay}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Sync Record List -->
                    <DataGrid x:Name="SyncRecordGrid" ItemsSource="{Binding SyncRecords}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              CanUserResizeColumns="True"
                              IsVisible="{Binding ShowSyncRecords}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding TimestampDisplay}" Width="150"/>
                            <DataGridTextColumn Header="仓库" Binding="{Binding RepoName}" Width="120"/>
                            <DataGridTextColumn Header="操作" Binding="{Binding OperationDisplay}" Width="80"/>
                            <DataGridTextColumn Header="文件" Binding="{Binding FilePath}" Width="*"/>
                            <DataGridTextColumn Header="结果" Binding="{Binding ResultDisplay}" Width="70"/>
                            <DataGridTextColumn Header="信息" Binding="{Binding Message}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="1" Classes="card" Margin="0,8,0,0" Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Sync status indicator -->
                    <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                             Fill="{Binding SyncStatus, Converter={x:Static converters:SyncStatusToColorConverter.Instance}}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusText}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding ItemCountText}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </Grid>
            </Border>

            <!-- Loading overlay -->
            <Border Grid.Row="0" Grid.RowSpan="2"
                    Background="#80000000"
                    IsVisible="{Binding IsLoading}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⏳ 处理中..." FontSize="16" Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>