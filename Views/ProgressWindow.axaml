<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OneFileBox.Views.ProgressWindow"
        Title="处理中"
        Width="440" Height="160"
        WindowStartupLocation="CenterOwner"
        
        CanResize="False"
        ShowInTaskbar="False">

    <Grid Margin="20,16" RowDefinitions="Auto,Auto,*,Auto">

        <!-- Status text above progress bar -->
        <TextBlock x:Name="StatusText" Grid.Row="0"
                   FontSize="12" Foreground="Gray"
                   Text="" Margin="0,0,0,8"
                   IsVisible="False"/>

        <!-- Progress bar -->
        <ProgressBar x:Name="ProgressBar" Grid.Row="1"
                     Height="20" Minimum="0" Maximum="100"
                     Margin="0,0,0,8"/>

        <!-- Cancel button -->
        <Button x:Name="CancelButton" Grid.Row="3"
                Content="取消" HorizontalAlignment="Right"
                MinWidth="90" Padding="16,7"
                IsVisible="False"
                Click="Cancel_Click"/>
    </Grid>
</Window>