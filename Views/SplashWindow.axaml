<Window xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="280"
       x:Class="OneFileBox.Views.SplashWindow"
       Title="OneFileBox"
       Height="280" Width="420"
       WindowStartupLocation="CenterScreen"
       CanResize="False"
       ShowTitle="False"
       Background="#1E88E5">

  <DockPanel Background="#1E88E5">

    <!-- App name / logo -->
    <StackPanel DockPanel.Dock="Top" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,20">
      <TextBlock Text="OneFileBox" FontSize="32" FontWeight="Bold" Foreground="White"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="SVN Based Sync" FontSize="14" Foreground="#BBDEFB"
                 HorizontalAlignment="Center" Margin="0,6,0,0"/>
    </StackPanel>

    <!-- Bottom step indicator -->
    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,20" HorizontalAlignment="Center">
      <TextBlock x:Name="StepText" Text="Step 1 / 3" FontSize="11" Foreground="#90CAF9"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Progress bar -->
    <ProgressBar x:Name="ProgressBar" DockPanel.Dock="Bottom" Height="4" Margin="40,0,40,12"
                 Minimum="0" Maximum="100" Value="0" Foreground="#BBDEFB" Background="#1565C0"/>

    <!-- Status message -->
    <TextBlock x:Name="StatusText"
               Text="Initializing..."
               FontSize="13" Foreground="White"
               HorizontalAlignment="Center" Margin="40,0,40,0"
               TextWrapping="Wrap" MaxWidth="340" TextAlignment="Center"
               VerticalAlignment="Center"/>

  </DockPanel>
</Window>