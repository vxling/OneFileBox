<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OneFileBox.Views.SyncRecordWindow"
        Title="同步历史记录"
        Width="700" Height="450"
        WindowStartupLocation="CenterOwner"
        
        CanResize="True">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="同步历史记录" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock x:Name="CountText" Text=" (0 条)" FontSize="13" Foreground="Gray" VerticalAlignment="Center" Margin="6,0,0,0"/>
        </StackPanel>

        <!-- Records list -->
        <DataGrid Grid.Row="1" x:Name="RecordsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1" BorderBrush="#E0E0E0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间" Binding="{Binding TimestampDisplay}" Width="150"/>
                <DataGridTextColumn Header="仓库" Binding="{Binding RepoNameDisplay}" Width="120"/>
                <DataGridTextColumn Header="操作" Binding="{Binding OperationDisplay}" Width="80"/>
                <DataGridTextColumn Header="文件" Binding="{Binding FilePathDisplay}" Width="*"/>
                <DataGridTextColumn Header="结果" Binding="{Binding ResultDisplay}" Width="70"/>
                <DataGridTextColumn Header="信息" Binding="{Binding Message}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="清空历史" Click="Clear_Click" MinWidth="90" Padding="14,6" Margin="0,0,10,0"/>
            <Button Content="关闭" Click="Close_Click" MinWidth="90" Padding="14,6"/>
        </StackPanel>
    </Grid>
</Window>